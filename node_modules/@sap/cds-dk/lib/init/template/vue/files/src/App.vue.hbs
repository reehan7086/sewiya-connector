<script setup>
import { ref, onMounted } from 'vue'

const books = ref([])

onMounted(async () => {
  const r = await fetch('/odata/v4/{{#isJava}}CatalogService{{/isJava}}{{^isJava}}catalog{{/isJava}}/Books')
  books.value = (await r.json()).value
})
</script>

<template>
  <main>
    <h1>Books</h1>
    <table>
      <tr v-for="b in books" :key="b.ID">
        <td>
          <span class="title">{{#literal}}{{ b.title }}{{/literal}}</span>{{^isJava}}
          <span class="author"><i>{{#literal}} by {{ b.author }}{{/literal}}</i></span>{{/isJava}}
        </td>
      </tr>
    </table>
  </main>
</template>

<style scoped>
.title {
  color: var(--text);
}

.author {
  color: var(--text-muted);
}
</style>
